# --- LLM (OpenRouter по умолчанию) ---
LLM_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=openai/gpt-4o

# Таймаут HTTP к LLM (секунды). Для облака обычно 300–600.
API_TIMEOUT=600

# Доп. параметры OpenAI API (JSON). Для OpenRouter оставьте пустым.
# EXTRA_BODY_JSON=

# Локальный LM Studio (вместо OpenRouter):
# LLM_BASE_URL=http://host.docker.internal:1234/v1
# LLM_API_KEY=lm-studio
# MODEL_NAME=gemma-4-26b-a4b-it-mlx
# EXTRA_BODY_JSON={"thinking":{"type":"disabled"}}

# --- Данные (Docker: том на /app/data) ---
DATA_DIR=/app/data

# --- Опционально ---
FIGMA_ACCESS_TOKEN=
MOBBIN_API_KEY=

# Порт HTTP-сервера (внутри контейнера)
PORT=8000
