# Виртуальное окружение Python
venv/

# Файлы с секретными ключами
.env

# Папка с историей прожарок (может быть большой)
references/history/

# Кэш Python
__pycache__/
*.pyc

# Папка для шрифтов (больше не используется)
fonts/

# Файлы macOS
.DS_Store

# База данных SQLite (у каждого пользователя своя история)
*.db